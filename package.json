{
  "name": "edms_ui",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@babel/runtime": "^7.26.10",
    "axios": "^0.24.0",
    "base-64": "^1.0.0",
    "core-js": "3.23.3",
    "country-list": "^2.2.0",
    "cronstrue": "^1.122.0",
    "cross-spawn": "^7.0.5",
    "env-cmd": "^10.1.0",
    "jest-sonar-reporter": "^2.0.0",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.29.4",
    "redux": "^4.0.5",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^2.3.0",
    "web-vitals": "^0.2.4",
    "xml2js": "^0.5.0"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
    "build": "set NODE_OPTIONS=--openssl-legacy-provider && react-scripts build",
    "start-stage": "env-cmd -r .env-cmdrc -e env, react-scripts start",
    "build-stage": "env-cmd -r .env-cmdrc -e env, react-scripts build",
    "test": "react-scripts test --env=jsdom --testResultsProcessor ./node_modules/jest-sonar-reporter/index.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/display-name": "off",
      "react/no-unknown-property": "off",
      "react/react-in-jsx-scope": "off",
      "react/jsx-uses-vars": "off",
      "react/jsx-no-undef": "off",
      "no-unused-vars": "off",
      "react/prop-types": "off",
      "react/jsx-no-duplicate-props": "off",
      "react/jsx-no-target-blank": "off",
      "no-empty": "off",
      "no-prototype-builtins": "off",
      "react/jsx-key": "off",
      "no-useless-escape": "off",
      "camelcase": "off",
      "react-hooks/exhaustive-deps": 0,
      "eqeqeq": 0
    }
  },
  "jest": {
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/store",
      "!src/test",
      "!node_modules",
      "!context",
      "!layout",
      "!fonts",
      "!images",
      "!locale",
      "!themes",
      "!static",
      "!utils",
      "!store",
      "!i18n.js",
      "!serviceWorker.js",
      "!.reducer.js",
      "!.style.js",
      "!.styles.js",
      "!.actions.js",
      "!.action.js",
      "!.types.js",
      "!.Types.js",
      "!.test.js",
      "!.form.js",
      "!.index.js",
      "!.RESTService.js",
      "!.RESTServiceWorkbench.js",
      "!.setupTests.js",
      "!.Location.js",
      "!.service.js",
      "!.services.js",
      "!stub",
      "!.page.js",
      "!.Page.js",
      "!.sagas.js",
      "!.saga.js",
      "!.wrappers.js",
      "!.Wrappers.js",
      "!.config.js",
      "!.Config.js",
      "!.Services.js",
      "!.Service.js",
      "!.world.js",
      "!.AnotationData.js",
      "!.leadsFormat.js",
      "!.utill.js",
      "!.selectors.js",
      "!.options.js",
      "!.Options.js",
      "!.Constant.js",
      "!.constant.js",
      "!.Dot.js",
      "!.LayoutContext.js",
      "!.utilFunctions.js",
      "!.style.js"
    ],
    "coveragePathIgnorePatterns": [
      "node_modules",
      ".service.js",
      ".services.js",
      "stub",
      "context",
      ".test.js",
      "layout",
      "fonts",
      "images",
      "locale",
      "themes",
      "static",
      "utils",
      "store",
      "i18n.js",
      "serviceWorker.js",
      ".page.js",
      ".Page.js",
      ".sagas.js",
      ".saga.js",
      ".reducer.js",
      ".style.js",
      ".styles.js",
      ".actions.js",
      ".action.js",
      ".types.js",
      ".Types.js",
      ".form.js",
      ".index.js",
      ".wrappers.js",
      ".Wrappers.js",
      ".config.js",
      ".Config.js",
      ".Services.js",
      ".Service.js",
      ".RESTService.js",
      ".RESTServiceWorkbench.js",
      ".setupTests.js",
      ".Location.js",
      ".world.js",
      ".AnotationData.js",
      ".leadsFormat.js",
      ".utill.js",
      ".selectors.js",
      ".options.js",
      ".Options.js",
      ".Constant.js",
      ".constant.js",
      ".Dot.js",
      ".LayoutContext.js",
      ".utilFunctions.js",
      ".style.js"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov",
      "cobertura"
    ],
    "moduleNameMapper": {
      "^components(.*)$": "<rootDir>/src/components$1"
    }
  },
  "jestSonar": {
    "sonar56x": true,
    "reportPath": "testResults",
    "reportFile": "sonar-report.xml",
    "indent": 4
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^11.2.2",
    "@testing-library/user-event": "^13.5.0",
    "antd": "4.9.2",
    "axios": "^0.24.0",
    "axios-delay": "^1.0.0-rc6",
    "core-js": "3.23.3",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.7",
    "enzyme-to-json": "^3.6.2",
    "react": "^16.13.1",
    "react-confirm-alert": "^2.7.0",
    "react-countdown": "^2.3.2",
    "react-country-region-selector": "^3.0.1",
    "react-dom": "^16.13.1",
    "react-highlight-words": "^0.20.0",
    "react-idle-timer": "^4.6.4",
    "react-json-tree": "^0.17.0",
    "react-redux": "^7.2.2",
    "react-router-dom": "^5.2.0",
    "react-scripts": "4.0.1"
  }
}
